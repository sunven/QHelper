{
  "name": "qhelper",
  "version": "1.2.0",
  "description": "QHelper前端助手 - Chrome/Chromium 扩展",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui",
    "test:e2e:debug": "pnpm build && playwright test --debug"
  },
  "keywords": [
    "chrome-extension",
    "developer-tools"
  ],
  "author": "sunven",
  "license": "ISC",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
