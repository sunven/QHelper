{
  "name": "qhelper",
  "version": "1.2.0",
  "description": "QHelper前端助手 - Chrome/Chromium 扩展",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui",
    "test:e2e:debug": "pnpm build && playwright test --debug"
  },
  "keywords": [
    "chrome-extension",
    "developer-tools"
  ],
  "author": "sunven",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "ajv": "^8.20.0",
    "antd": "^6.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "csso": "^5.0.5",
    "fast-xml-parser": "^5.7.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "marked": "^18.0.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-json-view": "^1.21.3",
    "react-router": "^7.15.0",
    "sass": "^1.99.0",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "toml-j0.4": "^1.1.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "uglify-js": "^3.19.3",
    "wxt": "^0.20.25"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.40",
    "@types/js-beautify": "^1.14.3",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^6.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "^4.1.5",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.5.0",
    "biome": "^0.3.3",
    "js-beautify": "^1.15.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-react": "5.2.0"
    }
  }
